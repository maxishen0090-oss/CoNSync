# =============================================================================
# Object build statements for STATIC_LIBRARY target dnssd


#############################################
# Order-only phony target for dnssd

build cmake_object_order_depends_target_dnssd: phony || .

build lib/dns_sd/CMakeFiles/dnssd.dir/dns_sd.c.obj: C_COMPILER__dnssd_unscanned_Release F$:/CNS/CoNSync/CoNSync-master/lib/dns_sd/dns_sd.c || cmake_object_order_depends_target_dnssd
