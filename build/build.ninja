  TARGET_FILE = lib\dns_sd\libdnssd.a
  TARGET_PDB = lib\dns_sd\libdnssd.pdb
  TARGET_SUPPORT_DIR = lib\dns_sd\CMakeFiles\dnssd.dir


#############################################
# Utility command for edit_cache

build lib/dns_sd/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\Windows\system32\cmd.exe /C "cd /D F:\CNS\CoNSync\CoNSync-master\build\lib\dns_sd && F:\msys64\ucrt64\bin\cmake.exe -E echo "No interactive CMake dialog available.""
