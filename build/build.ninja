  OBJECT_FILE_DIR = lib\dns_sd\CMakeFiles\dnssd.dir
  TARGET_COMPILE_PDB = lib\dns_sd\CMakeFiles\dnssd.dir\dnssd.pdb
  TARGET_PDB = lib\dns_sd\libdnssd.pdb
  TARGET_SUPPORT_DIR = lib\dns_sd\CMakeFiles\dnssd.dir


# =============================================================================
# Link build statements for STATIC_LIBRARY target dnssd


#############################################
# Link the static library lib\dns_sd\libdnssd.a

build lib/dns_sd/libdnssd.a: C_STATIC_LIBRARY_LINKER__dnssd_Release lib/dns_sd/CMakeFiles/dnssd.dir/dns_sd.c.obj
  CONFIG = Release
  LANGUAGE_COMPILE_FLAGS = -O3 -DNDEBUG
  OBJECT_DIR = lib\dns_sd\CMakeFiles\dnssd.dir
