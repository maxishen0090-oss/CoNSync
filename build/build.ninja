  DEP_FILE = lib\dns_sd\CMakeFiles\dnssd.dir\dns_sd.c.obj.d
  FLAGS = -O3 -DNDEBUG
  INCLUDES = -IF:/CNS/CoNSync/CoNSync-master/playfair -IF:/CNS/CoNSync/CoNSync-master/llhttp -IF:/CNS/CoNSync/CoNSync-master/lib -IF:/CNS/CoNSync/CoNSync-master/lib/dns_sd/. -I"C:/Program Files/Bonjour SDK/Include"
